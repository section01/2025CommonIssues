{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref } from 'vue';\nimport { useRouter } from 'vue-router';\nimport CommonHeader from '@/components/common/CommonHeader.vue'; // 共通ヘッダー\n\nexport default {\n  __name: 'LoginForm',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const userId = ref('');\n    const password = ref('');\n    const message = ref('画面上部メッセージ');\n    const router = useRouter();\n    const handleLogin = async () => {\n      if (!userId.value || !password.value) {\n        message.value = 'ユーザIDとパスワードを入力してください';\n        return;\n      }\n      try {\n        // DB検索を想定したAPI呼び出し（モック用）\n        const response = await fetch('/api/login', {\n          method: 'POST',\n          headers: {\n            'Content-Type': 'application/json'\n          },\n          body: JSON.stringify({\n            userId: userId.value,\n            password: password.value\n          })\n        });\n        if (!response.ok) {\n          throw new Error('サーバエラー');\n        }\n        const result = await response.json();\n        if (result.success) {\n          message.value = 'ログイン成功';\n          router.push('/menu');\n        } else {\n          message.value = 'ユーザIDまたはパスワードが正しくありません';\n        }\n      } catch (err) {\n        console.error(err);\n        message.value = '通信エラーが発生しました';\n      }\n    };\n    const handleClear = () => {\n      userId.value = '';\n      password.value = '';\n      message.value = '画面上部メッセージ';\n    };\n\n    /** \n    const handleLogin = () => {\n      // ここでログイン認証処理をする場合は追加\n      // 今はモックなので必ず遷移させる\n    \n      router.push('/menu')  // '/menu' に遷移\n    }\n    \n    const handleClear = () => {\n      userId.value = ''\n      password.value = ''\n    }\n    */\n\n    const __returned__ = {\n      userId,\n      password,\n      message,\n      router,\n      handleLogin,\n      handleClear,\n      ref,\n      get useRouter() {\n        return useRouter;\n      },\n      CommonHeader\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","useRouter","CommonHeader","userId","password","message","router","handleLogin","value","response","fetch","method","headers","body","JSON","stringify","ok","Error","result","json","success","push","err","console","error","handleClear"],"sources":["C:/Users/yu-yoshida/Desktop/pleiades-2025-06-java-win-64bit-jre_20250615/workspace/kintai/vue/src/components/LoginForm.vue"],"sourcesContent":["<template>\n  <div class=\"login-container\">\n    <!-- ヘッダー -->\n    <CommonHeader title=\"ログイン\" />\n\n    <!-- メッセージエリア -->\n    <div class=\"message-area\">{{ message }}</div>\n\n    <!-- 入力エリア -->\n    <div class=\"form-area\">\n      <div class=\"form-row\">\n        <label for=\"userId\">ユーザID</label>\n        <input type=\"text\" id=\"userId\" v-model=\"userId\" />\n      </div>\n      <div class=\"form-row\">\n        <label for=\"password\">パスワード</label>\n        <input type=\"password\" id=\"password\" v-model=\"password\" />\n      </div>\n    </div>\n\n    <!-- ボタンエリア -->\n    <div class=\"button-area\">\n      <button @click=\"handleLogin\">ログイン</button>\n      <button @click=\"handleClear\">クリア</button>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref } from 'vue'\nimport { useRouter } from 'vue-router'\nimport CommonHeader from '@/components/common/CommonHeader.vue'  // 共通ヘッダー\n\n\nconst userId = ref('')\nconst password = ref('')\nconst message = ref('画面上部メッセージ')\n\nconst router = useRouter()\n\n\nconst handleLogin = async () => {\n  if (!userId.value || !password.value) {\n    message.value = 'ユーザIDとパスワードを入力してください'\n    return\n  }\n\n  try {\n    // DB検索を想定したAPI呼び出し（モック用）\n    const response = await fetch('/api/login', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({\n        userId: userId.value,\n        password: password.value\n      })\n    })\n\n    if (!response.ok) {\n      throw new Error('サーバエラー')\n    }\n\n    const result = await response.json()\n\n    if (result.success) {\n      message.value = 'ログイン成功'\n      router.push('/menu')\n    } else {\n      message.value = 'ユーザIDまたはパスワードが正しくありません'\n    }\n  } catch (err) {\n    console.error(err)\n    message.value = '通信エラーが発生しました'\n  }\n}\n\nconst handleClear = () => {\n  userId.value = ''\n  password.value = ''\n  message.value = '画面上部メッセージ'\n}\n\n/** \nconst handleLogin = () => {\n  // ここでログイン認証処理をする場合は追加\n  // 今はモックなので必ず遷移させる\n\n  router.push('/menu')  // '/menu' に遷移\n}\n\nconst handleClear = () => {\n  userId.value = ''\n  password.value = ''\n}\n*/\n</script>\n\n<style scoped>\n\n/* メッセージエリア */\n.message-area {\n  padding: 10px;\n  border-bottom: 1px solid #000;\n  font-size: 14px;\n}\n\n/* 入力フォームエリア */\n.form-area {\n  padding: 20px 30px 10px;\n}\n\n.form-row {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  margin-bottom: 15px;\n}\n\n/* 入力欄名(ユーザIDとか) */\nlabel {\n  width: 100px;\n  font-size: 14px;\n  text-align: right;\n  margin-right: 8px;\n}\n\n/* 入力欄 */\ninput {\n  flex: none;\n  width: 50%;\n  padding: 5px;\n  font-size: 14px;\n  border: 1px solid #000;\n}\n\n/* ボタンエリア */\n.button-area {\n  display: flex;\n  justify-content: center;\n  gap: 20px;\n  padding: 20px;\n}\n\nbutton {\n  padding: 8px 20px;\n  background-color: #d9d9d9;\n  border: 1px solid #000;\n  cursor: pointer;\n}\n\nbutton:hover {\n  background-color: #c0c0c0;\n}\n</style>\n"],"mappings":";AA6BA,SAASA,GAAG,QAAQ,KAAI;AACxB,SAASC,SAAS,QAAQ,YAAW;AACrC,OAAOC,YAAY,MAAM,sCAAsC,EAAE;;;;;;;;IAGjE,MAAMC,MAAM,GAAGH,GAAG,CAAC,EAAE;IACrB,MAAMI,QAAQ,GAAGJ,GAAG,CAAC,EAAE;IACvB,MAAMK,OAAO,GAAGL,GAAG,CAAC,WAAW;IAE/B,MAAMM,MAAM,GAAGL,SAAS,CAAC;IAGzB,MAAMM,WAAW,GAAG,MAAAA,CAAA,KAAY;MAC9B,IAAI,CAACJ,MAAM,CAACK,KAAK,IAAI,CAACJ,QAAQ,CAACI,KAAK,EAAE;QACpCH,OAAO,CAACG,KAAK,GAAG,sBAAqB;QACrC;MACF;MAEA,IAAI;QACF;QACA,