{"ast":null,"code":"export default {\n  name: \"CommonHeader\",\n  props: {\n    title: {\n      type: String,\n      required: true\n    },\n    showUser: {\n      type: Boolean,\n      default: false\n    }\n  },\n  data() {\n    return {\n      user: {\n        userName: \"\",\n        userId: \"\",\n        role: \"\",\n        name: \"\",\n        team: \"\"\n      }\n    };\n  },\n  mounted() {\n    // sessionStorage から user を取得して設定\n    const storedUser = sessionStorage.getItem('user');\n    if (storedUser) {\n      try {\n        const parsed = JSON.parse(storedUser);\n        this.user.userName = parsed.userName || \"\";\n        this.user.userId = parsed.userId || \"\";\n        this.user.role = parsed.role || \"\";\n        this.user.name = parsed.name || \"\";\n        this.user.team = parsed.team || \"\";\n      } catch (e) {\n        console.error('sessionStorageのuserが不正です', e);\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","props","title","type","String","required","showUser","Boolean","default","data","user","userName","userId","role","team","mounted","storedUser","sessionStorage","getItem","parsed","JSON","parse","e","console","error"],"sources":["C:\\Users\\yu-yoshida\\Desktop\\pleiades-2025-06-java-win-64bit-jre_20250615\\workspace\\kintai\\vue\\src\\components\\common\\CommonHeader.vue"],"sourcesContent":["<template>\n  <header class=\"common-header\">\n    <!-- 左側：画面名 -->\n    <div class=\"header-left\">\n      {{ title }}\n    </div>\n\n    <!-- 右側：ユーザ情報（必要なときだけ表示） -->\n    <div class=\"header-right\" v-if=\"showUser\">\n      <span>役職：{{ user.role }}</span>\n      <span>名前：{{ user.name }}</span>\n      <span>所属チーム：{{ user.team }}</span>\n    </div>\n  </header>\n</template>\n\n<script>\nexport default {\n  name: \"CommonHeader\",\n\n  props: {\n    title: { type: String, required: true },\n    showUser: { type: Boolean, default: false }\n  },\n\n  data() {\n    return {\n      user: {\n        userName: \"\",\n        userId: \"\",\n        role: \"\",\n        name: \"\",\n        team: \"\"\n      }\n    }\n  },\n\n  mounted() {\n    // sessionStorage から user を取得して設定\n    const storedUser = sessionStorage.getItem('user')\n    if (storedUser) {\n      try {\n        const parsed = JSON.parse(storedUser)\n        this.user.userName = parsed.userName || \"\"\n        this.user.userId = parsed.userId || \"\"\n        this.user.role = parsed.role || \"\"\n        this.user.name = parsed.name || \"\"\n        this.user.team = parsed.team || \"\"\n      } catch (e) {\n        console.error('sessionStorageのuserが不正です', e)\n      }\n    }\n  }\n}\n</script>\n\n<style scoped>\n.common-header {\n  width: 100%;\n  height: 60px;\n  background-color: #8ebc75; /* 背景色 */\n  color: white;\n  display: flex;\n  justify-content: space-between; /* 左右に配置 */\n  align-items: center;\n  padding: 0 20px;\n  box-sizing: border-box;\n  border: 1px solid #000;\n}\n.header-left {\n  font-size: 18px;\n  font-weight: bold;\n}\n.header-right span {\n  margin-left: 15px;\n  font-size: 14px;\n}\n</style>"],"mappings":"AAiBA,eAAe;EACbA,IAAI,EAAE,cAAc;EAEpBC,KAAK,EAAE;IACLC,KAAK,EAAE;MAAEC,IAAI,EAAEC,MAAM;MAAEC,QAAQ,EAAE;IAAK,CAAC;IACvCC,QAAQ,EAAE;MAAEH,IAAI,EAAEI,OAAO;MAAEC,OAAO,EAAE;IAAM;EAC5C,CAAC;EAEDC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,IAAI,EAAE;QACJC,QAAQ,EAAE,EAAE;QACZC,MAAM,EAAE,EAAE;QACVC,IAAI,EAAE,EAAE;QACRb,IAAI,EAAE,EAAE;QACRc,IAAI,EAAE;MACR;IACF;EACF,CAAC;EAEDC,OAAOA,CAAA,EAAG;IACR;IACA,MAAMC,UAAS,GAAIC,cAAc,CAACC,OAAO,CAAC,MAAM;IAChD,IAAIF,UAAU,EAAE;MACd,IAAI;QACF,MAAMG,MAAK,GAAIC,IAAI,CAACC,KAAK,CAACL,UAAU;QACpC,IAAI,CAACN,IAAI,CAACC,QAAO,GAAIQ,MAAM,CAACR,QAAO,IAAK,EAAC;QACzC,IAAI,CAACD,IAAI,CAACE,MAAK,GAAIO,MAAM,CAACP,MAAK,IAAK,EAAC;QACrC,IAAI,CAACF,IAAI,CAACG,IAAG,GAAIM,MAAM,CAACN,IAAG,IAAK,EAAC;QACjC,IAAI,CAACH,IAAI,CAACV,IAAG,GAAImB,MAAM,CAACnB,IAAG,IAAK,EAAC;QACjC,IAAI,CAACU,IAAI,CAACI,IAAG,GAAIK,MAAM,CAACL,IAAG,IAAK,EAAC;MACnC,EAAE,OAAOQ,CAAC,EAAE;QACVC,OAAO,CAACC,KAAK,CAAC,0BAA0B,EAAEF,CAAC;MAC7C;IACF;EACF