{"ast":null,"code":"export default {\n  name: \"CommonHeader\",\n  props: {\n    title: {\n      type: String,\n      required: true\n    },\n    // 画面名\n    showUser: {\n      type: Boolean,\n      default: false\n    },\n    // ユーザ情報を表示するか\n    user: {\n      type: Object,\n      required: false\n    }\n  },\n  computed: {\n    roleName() {\n      if (!this.user || !this.user.role) return \"\";\n      const roleMap = {\n        1: \"社員\",\n        2: \"チーフ\",\n        3: \"リーダー\",\n        4: \"アシスタントマネージャー\",\n        5: \"マネージャー\"\n      };\n      return roleMap[this.user.role] || \"不明\";\n    }\n  }\n};","map":{"version":3,"names":["name","props","title","type","String","required","showUser","Boolean","default","user","Object","computed","roleName","role","roleMap"],"sources":["C:\\Users\\y-uesaka\\Desktop\\workspace\\KintaiProject\\vue\\src\\components\\common\\CommonHeader.vue"],"sourcesContent":["<template>\n  <header class=\"common-header\">\n    <!-- 左側：画面名 -->\n    <div class=\"header-left\">\n      {{ title }}\n    </div>\n\n    <!-- 右側：ユーザ情報（必要なときだけ表示） -->\n    <div class=\"header-right\" v-if=\"showUser && user\">\n      <span>役職：{{ roleName }}</span>\n      <span>名前：{{ user.empLname }} {{ user.empFname }}</span>\n      <span>所属チーム：{{ \"セクション1\" }}</span>\n    </div>\n  </header>\n</template>\n\n<script>\nexport default {\n  name: \"CommonHeader\",\n  props: {\n    title: { type: String, required: true }, // 画面名\n    showUser: { type: Boolean, default: false }, // ユーザ情報を表示するか\n    user: { type: Object, required: false }\n    },\n      computed: {\n          roleName() {\n              if (!this.user || !this.user.role) return \"\"\n\n              const roleMap = {\n                  1: \"社員\",\n                  2: \"チーフ\",\n                  3: \"リーダー\",\n                  4: \"アシスタントマネージャー\",\n                  5: \"マネージャー\"\n              }\n            return roleMap[this.user.role] || \"不明\"\n          }\n       }\n}\n</script>\n\n<style scoped>\