"\n          min=\"0\"\n          max=\"59\"\n          placeholder=\"分\"\n          required\n          style=\"width: 50px; margin-left: 10px;\"\n        /> 分\n      </div>\n\n      <div style=\"margin-bottom: 10px;\">\n        <label>理由</label>\n        <select v-model=\"reason\" required>\n          <option disabled value=\"\">選択してください</option>\n          <option value=\"電車遅延\">電車遅延</option>\n          <option value=\"寝坊\">寝坊</option>\n          <option value=\"体調不良\">体調不良</option>\n          <option value=\"その他\">その他</option>\n        </select>\n      </div>\n\n      <div style=\"margin-bottom: 10px;\">\n        <label>電車</label>\n        <input\n          type=\"text\"\n          v-model=\"trainLine\"\n          :required=\"reason === '電車遅延'\"\n          :disabled=\"reason !== '電車遅延'\"\n        />\n      </div>\n\n      <div style=\"margin-bottom: 10px;\">\n        <label>遅延時間</label>\n        <input\n          type=\"number\"\n          v-model.number=\"delayTime\"\n          required\n          min=\"0\"\n          style=\"width: 60px;\"\n        /> 分\n      </div>\n\n      <div style=\"margin-bottom: 10px;\">\n        <label>本文</label><br />\n        <textarea v-model=\"body\" required rows=\"5\" cols=\"40\" />\n      </div>\n\n      <div>\n        <button type=\"submit\">登録</button>\n        <button type=\"button\" @click=\"goBack\" style=\"margin-left: 20px;\">戻る</button>\n      </div>\n    </form>\n  </div>\n</template>\n\n<script setup>\nimport CommonHeader from '@/components/common/CommonHeader.vue'\nimport { ref, onMounted } from 'vue'\nimport { useRouter } from 'vue-router'\n\nconst router = useRouter()\n\n// ユーザ情報\nconst user = ref({\n  role: '',\n  empLname: '',\n  teamName: ''\n})\n\n// ログイン時に保存したユーザ情報を取得\nonMounted(() => {\n  const storedUser = sessionStorage.getItem('user')\n  if (storedUser) {\n    user.value = JSON.parse(storedUser)\n  }\n})\n\n// 日付フォームなど\nconst date = ref(getTodayDate())\nconst startHour = ref(null)\nconst startMinute = ref(null)\nconst reason = ref('')\nconst trainLine = ref('')\nconst delayTime = ref(null)\nconst body = ref('')\n\n// 今日の日付を返す\nfunction getTodayDate() {\n  const today = new Date()\n  const y = today.getFullYear()\n  const m = String(today.getMonth() + 1).padStart(2, '0')\n  const d = String(today.getDate()).padStart(2, '0')\n  return `${y}-${m}-${d}`\n}\n\n// フォーム送信\nfunction submit() {\n  if (startHour.value === null) {\n    alert('始業時間は必須です')\n    return\n  }\n  if (!reason.value) {\n    alert('理由は必須です')\n    return\n  }\n  if (reason.value === '電車遅延' && !trainLine.value) {\n    alert('電車は理由が電車遅延の場合必須です')\n    return\n  }\n  if (delayTime.value === null) {\n    alert('遅延時間は必須です')\n    return\n  }\n  if (!body.value) {\n    alert('本文は必須です')\n    return\n  }\n  alert('登録処理を実行します')\n}\n\n// メニューに戻る\nfunction goMenu() {\n  sessionStorage.setItem('user', JSON.stringify(user.value))\n  router.push('/menu')\n}\n\nfunction goBack() {\n  goMenu()\n}\n</script>\n\n<style scoped>\nlabel {\n  display: inline-block;\n  width: 70px;\n  vertical-align: top;\n}\n</style>\n"],"mappings":";AAyFA,OAAOA,YAAY,MAAM,sCAAqC;AAC9D,SAASC,GAAG,EAAEC,SAAS,QAAQ,KAAI;AACnC,SAASC,SAAS,QAAQ,YAAW;;;;;;;IAErC,MAAMC,MAAM,GAAGD,SAAS,CAAC;;IAEzB;IACA,MAAME,IAAI,GAAGJ,GAAG,CAAC;MACfK,IAAI,EAAE,EAAE;MACRC,QAAQ,EAAE,EAAE;MACZC,QAAQ,EAAE;IACZ,CAAC;;IAED;IACAN,SAAS,CAAC,MAAM;MACd,MAAMO,UAAU,GAAGC,cAAc,CAACC,OAAO,CAAC,MAAM;MAChD,IAAIF,UAAU,EAAE;QACdJ,IAAI,CAACO,KAAK,GAAGC,IAAI,CAACC,KAAK,CAACL,UAAU;MACpC;IACF,CAAC;;IAED;IACA,MAAMM,IAAI,GAAGd,GAAG,CAACe,YAAY,CAAC,CAAC;IAC/B,MAAMC,SAAS,GAAGhB,GAAG,CAAC,IAAI;IAC1B,MAAMiB,WAAW,GAAGjB,GAAG,CAAC,IAAI;IAC5B,MAAMkB,MAAM,GAAGlB,GAAG,CAAC,EAAE;IACrB,MAAMmB,SAAS,GAAGnB,GAAG,CAAC,EAAE;IACxB,MAAMoB,SAAS,GAAGpB,GAAG,CAAC,IAAI;IAC1B,MAAMqB,IAAI,GAAGrB,GAAG,CAAC,EAAE;;IAEnB;IACA,SAASe,YAAYA,CAAA,EAAG;MACtB,MAAMO,KAAK,GAAG,IAAIC,IAAI,CAAC;MACvB,MAAMC,CAAC,GAAGF,KAAK,CAACG,WAAW,CAAC;MAC5B,MAAMC,CAAC,GAAGC,MAAM,CAACL,KAAK,CAACM,QAAQ,CAAC,CAAC,GAAG,CAAC,CAAC,CAACC,QAAQ,CAAC,CAA