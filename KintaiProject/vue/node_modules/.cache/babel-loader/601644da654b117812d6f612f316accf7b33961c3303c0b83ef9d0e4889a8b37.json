{"ast":null,"code":"import { reactive, onMounted } from 'vue';\n\n// コンポーネント側から受け取る props（必要であれば残す）\n\nexport default {\n  __name: 'CommonHeader',\n  props: {\n    showUser: {\n      type: Boolean,\n      default: false\n    }\n  },\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const props = __props;\n\n    // ヘッダーに表示する user 情報を保持\n    const user = reactive({\n      userName: \"\",\n      userId: \"\",\n      role: \"\",\n      name: \"\",\n      team: \"\"\n    });\n\n    // 画面表示のたびに sessionStorage から user を読み込む\n    onMounted(() => {\n      const storedUser = sessionStorage.getItem('user');\n      if (storedUser) {\n        try {\n          const parsed = JSON.parse(storedUser);\n          user.userName = parsed.userName || \"\";\n          user.userId = parsed.userId || \"\";\n          user.role = parsed.role || \"\";\n          user.name = parsed.name || \"\";\n          user.team = parsed.team || \"\";\n        } catch (e) {\n          console.error('sessionStorageのuserが不正です', e);\n        }\n      }\n    });\n    const __returned__ = {\n      props,\n      user,\n      reactive,\n      onMounted\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["reactive","onMounted","props","__props","user","userName","userId","role","name","team","storedUser","sessionStorage","getItem","parsed","JSON","parse","e","console","error"],"sources":["C:/Users/yu-yoshida/Desktop/pleiades-2025-06-java-win-64bit-jre_20250615/workspace/kintai/vue/src/components/common/CommonHeader.vue"],"sourcesContent":["<template>\n  <header class=\"common-header\">\n    <!-- 左側：画面名 -->\n    <div class=\"header-left\">\n      {{ title }}\n    </div>\n\n    <!-- 右側：ユーザ情報（必要なときだけ表示） -->\n    <div class=\"header-right\" v-if=\"props.showUser\">\n      <span>役職：{{ user.role }}</span>\n      <span>名前：{{ user.name }}</span>\n      <span>所属チーム：{{ user.team }}</span>\n    </div>\n  </header>\n</template>\n\n<script setup>\nimport { reactive, onMounted } from 'vue'\n\n// コンポーネント側から受け取る props（必要であれば残す）\nconst props = defineProps({\n  showUser: { type: Boolean, default: false }\n})\n\n// ヘッダーに表示する user 情報を保持\nconst user = reactive({\n  userName: \"\",\n  userId: \"\",\n  role: \"\",\n  name: \"\",\n  team: \"\"\n})\n\n// 画面表示のたびに sessionStorage から user を読み込む\nonMounted(() => {\n  const storedUser = sessionStorage.getItem('user')\n  if (storedUser) {\n    try {\n      const parsed = JSON.parse(storedUser)\n      user.userName = parsed.userName || \"\"\n      user.userId = parsed.userId || \"\"\n      user.role = parsed.role || \"\"\n      user.name = parsed.name || \"\"\n      user.team = parsed.team || \"\"\n    } catch (e) {\n      console.error('sessionStorageのuserが不正です', e)\n    }\n  }\n})\n</script>\n\n<style scoped>\n.common-header {\n  width: 100%;\n  height: 60px;\n  background-color: #8ebc75; /* 背景色 */\n  color: white;\n  display: flex;\n  justify-content: space-between; /* 左右に配置 */\n  align-items: center;\n  padding: 0 20px;\n  box-sizing: border-box;\n  border: 1px solid #000;\n}\n.header-left {\n  font-size: 18px;\n  font-weight: bold;\n}\n.header-right span {\n  margin-left: 15px;\n  font-size: 14px;\n}\n</style>"],"mappings":"AAiBA,SAASA,QAAQ,EAAEC,SAAS,QAAQ,KAAI;;AAExC;;;;;;;;;;;;;;IACA,MAAMC,KAAK,GAAGC,OAAA;;IAId;IACA,MAAMC,IAAI,GAAGJ,QAAQ,CAAC;MACpBK,QAAQ,EAAE,EAAE;MACZC,MAAM,EAAE,EAAE;MACVC,IAAI,EAAE,EAAE;MACRC,IAAI,EAAE,EAAE;MACRC,IAAI,EAAE;IACR,CAAC;;IAED;IACAR,SAAS,CAAC,MAAM;MACd,MAAMS,UAAU,GAAGC,cAAc,CAACC,OAAO,CAAC,MAAM;MAChD,IAAIF,UAAU,EAAE;QACd,IAAI;UACF,MAAMG,MAAM,GAAGC,IAAI,CAACC,KAAK,CAACL,UAAU;UACpCN,IAAI,CAACC,QAAQ,GAAGQ,MAAM,CAACR,QAAQ,IAAI,EAAC;UACpCD,IAAI,CAACE,MAAM,GAAGO,MAAM,CAACP,MAAM,IAAI,EAAC;UAChCF,IAAI,CAACG,IAAI,GAAGM,MAAM,CAACN,IAAI,IAAI,EAAC;UAC5BH,IAAI,CAACI,IAAI,GAAGK,MAAM,CAACL,IAAI,IAAI,EAAC;UAC5BJ,IAAI,CAACK,IAAI,GAAGI,MAAM,CAACJ,IAAI,IAAI,EAAC;QAC9B,CAAC,CAAC,OAA