{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport CommonHeader from '@/components/common/CommonHeader.vue'; // 共通ヘッダー\nimport { onMounted, ref } from 'vue'; // セッションストレージ\nimport { useRouter } from 'vue-router';\nconst router = useRouter();\nconst user = ref(null);\nonMounted(() => {\n  // ログイン時に保存したユーザ情報を取得\n  const storedUser = sessionStorage.getItem('user');\n  if (storedUser) {\n    user.value = JSON.parse(storedUser);\n  }\n});\nconst goKintaiInput = () => {\n  router.push('/kintai-input');\n};\nexport default {\n  name: \"KintaiInput\",\n  components: {\n    CommonHeader\n  },\n  data() {\n    return {\n      date: this.getTodayDate(),\n      startHour: null,\n      startMinute: null,\n      reason: \"\",\n      trainLine: \"\",\n      delayTime: null,\n      body: \"\"\n    };\n  },\n  methods: {\n    getTodayDate() {\n      const today = new Date();\n      const y = today.getFullYear();\n      const m = String(today.getMonth() + 1).padStart(2, \"0\");\n      const d = String(today.getDate()).padStart(2, \"0\");\n      return `${y}-${m}-${d}`;\n    },\n    submit() {\n      // 必須チェックはブラウザのrequired属性に任せるが、念のため簡易チェック\n      if (!this.startHour && this.startHour !== 0) {\n        alert(\"始業時間は必須です\");\n        return;\n      }\n      if (!this.reason) {\n        alert(\"理由は必須です\");\n        return;\n      }\n      if (this.reason === \"電車遅延\" && !this.trainLine) {\n        alert(\"電車は理由が電車遅延の場合必須です\");\n        return;\n      }\n      if (this.delayTime === null) {\n        alert(\"遅延時間は必須です\");\n        return;\n      }\n      if (!this.body) {\n        alert(\"本文は必須です\");\n        return;\n      }\n      alert(\"登録処理を実行します\");\n      // ここに実際の登録処理を追加\n    },\n    goBack() {\n      // ルーターでメニュー画面に遷移\n      this.$router.push(\"/menu\");\n    }\n  }\n};","map":{"version":3,"names":["CommonHeader","onMounted","ref","useRouter","router","user","storedUser","sessionStorage","getItem","value","JSON","parse","goKintaiInput","push","name","components","data","date","getTodayDate","startHour","startMinute","reason","trainLine","delayTime","body","methods","today","Date","y","getFullYear","m","String","getMonth","padStart","d","getDate","submit","alert","goBack","$router"],"sources":["C:\\Users\\yu-yoshida\\Desktop\\pleiades-2025-06-java-win-64bit-jre_20250615\\workspace\\kintai\\vue\\src\\components\\KintaiInput.vue"],"sourcesContent":["<template>\n\t<div>\n\t\t<div class=\"common-container menu-container\">\n\t\t\t<CommonHeader \n\t\t\t\ttitle=\"メニュー\" \n\t\t\t\t:showUser=\"true\" \n\t\t\t\t:user=\"user\"\n\t\t\t/>\n\t\t</div>\n    <!-- 上部メッセージ -->\n    <div style=\"border: 1px solid black; padding: 10px; margin-top: 5px;\">\n      画面上部メッセージ\n    </div>\n\n    <!-- 入力フォーム -->\n    <form @submit.prevent=\"submit\" style=\"border: 1px solid black; padding: 10px; margin-top: 5px;\">\n      <div style=\"margin-bottom: 10px;\">\n        <label>日付</label>\n        <input type=\"date\" v-model=\"date\" required />\n      </div>\n\n      <div style=\"margin-bottom: 10px;\">\n        <label>始業時間</label>\n        <input\n          type=\"number\"\n          v-model.number=\"startHour\"\n          min=\"0\"\n          max=\"23\"\n          placeholder=\"時\"\n          required\n          style=\"width: 50px;\"\n        /> 時\n        <input\n          type=\"number\"\n          v-model.number=\"startMinute\"\n          min=\"0\"\n          max=\"59\"\n          placeholder=\"分\"\n          required\n          style=\"width: 50px; margin-left: 10px;\"\n        /> 分\n      </div>\n\n      <div style=\"margin-bottom: 10px;\">\n        <label>理由</label>\n        <select v-model=\"reason\" required>\n          <option disabled value=\"\">選択してください</option>\n          <option value=\"電車遅延\">電車遅延</option>\n          <option value=\"寝坊\">寝坊</option>\n          <option value=\"体調不良\">体調不良</option>\n          <option value=\"その他\">その他</option>\n        </select>\n      </div>\n\n      <div style=\"margin-bottom: 10px;\">\n        <label>電車</label>\n        <input\n          type=\"text\"\n          v-model=\"trainLine\"\n          :required=\"reason === '電車遅延'\"\n          :disabled=\"reason !== '電車遅延'\"\n        />\n      </div>\n\n      <div style=\"margin-bottom: 10px;\">\n        <label>遅延時間</label>\n        <input\n          type=\"number\"\n          v-model.number=\"delayTime\"\n          required\n          min=\"0\"\n          style=\"width: 60px;\"\n        /> 分\n      </div>\n\n      <div style=\"margin-bottom: 10px;\">\n        <label>本文</label><br />\n        <textarea v-model=\"body\" required rows=\"5\" cols=\"40\" />\n      </div>\n\n      <div>\n        <button type=\"submit\">登録</button>\n        <button type=\"button\" @click=\"goBack\" style=\"margin-left: 20px;\">戻る</button>\n      </div>\n    </form>\n  </div>\n</template>\n\n<script>\nimport CommonHeader from '@/components/common/CommonHeader.vue'  // 共通ヘッダー\nimport { onMounted, ref } from 'vue' // セッションストレージ\nimport { useRouter } from 'vue-router'\n\n\nconst router = useRouter()\nconst user = ref(null)\n\nonMounted(() => {\n\t// ログイン時に保存したユーザ情報を取得\n\tconst storedUser = sessionStorage.getItem('user')\n\tif (storedUser) {\n\t\tuser.value = JSON.parse(storedUser)\n\t}\n})\n\nconst goKintaiInput = () => {\n\trouter.push('/kintai-input')\n}\n\nexport default {\n  name: \"KintaiInput\",\n  components: { CommonHeader },\n  data() {\n    return {\n      date: this.getTodayDate(),\n      startHour: null,\n      startMinute: null,\n      reason: \"\",\n      trainLine: \"\",\n      delayTime: null,\n      body: \"\",\n    };\n  },\n  methods: {\n    getTodayDate() {\n      const today = new Date();\n      const y = today.getFullYear();\n      const m = String(today.getMonth() + 1).padStart(2, \"0\");\n      const d = String(today.getDate()).padStart(2, \"0\");\n      return `${y}-${m}-${d}`;\n    },\n    submit() {\n      // 必須チェックはブラウザのrequired属性に任せるが、念のため簡易チェック\n      if (!this.startHour && this.startHour !== 0) {\n        alert(\"始業時間は必須です\");\n        return;\n      }\n      if (!this.reason) {\n        alert(\"理由は必須です\");\n        return;\n      }\n      if (this.reason === \"電車遅延\" && !this.trainLine) {\n        alert(\"電車は理由が電車遅延の場合必須です\");\n        return;\n      }\n      if (this.delayTime === null) {\n        alert(\"遅延時間は必須です\");\n        return;\n      }\n      if (!this.body) {\n        alert(\"本文は必須です\");\n        return;\n      }\n      alert(\"登録処理を実行します\");\n      // ここに実際の登録処理を追加\n    },\n    goBack() {\n      // ルーターでメニュー画面に遷移\n      this.$router.push(\"/menu\");\n    },\n  },\n};\n</script>\n\n<style scoped>\nlabel {\n  display: inline-block;\n  width: 70px;\n  vertical-align: top;\n}\n</style>\n"],"mappings":";AAyFA,OAAOA,YAAW,MAAO,sCAAqC,EAAG;AACjE,SAASC,SAAS,EAAEC,GAAE,QAAS,KAAI,EAAE;AACrC,SAASC,SAAQ,QAAS,YAAW;AAGrC,MAAMC,MAAK,GAAID,SAAS,CAAC;AACzB,MAAME,IAAG,GAAIH,GAAG,CAAC,IAAI;AAErBD,SAAS,CAAC,MAAM;EACf;EACA,MAAMK,UAAS,GAAIC,cAAc,CAACC,OAAO,CAAC,MAAM;EAChD,IAAIF,UAAU,EAAE;IACfD,IAAI,CAACI,KAAI,GAAIC,IAAI,CAACC,KAAK,CAACL,UAAU;EACnC;AACD,CAAC;AAED,MAAMM,aAAY,GAAIA,CAAA,KAAM;EAC3BR,MAAM,CAACS,IAAI,CAAC,eAAe;AAC5B;AAEA,eAAe;EACbC,IAAI,EAAE,aAAa;EACnBC,UAAU,EAAE;IAAEf;EAAa,CAAC;EAC5BgB,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,IAAI,EAAE,IAAI,CAACC,YAAY,CAAC,CAAC;MACzBC,SAAS,EAAE,IAAI;MACfC,WAAW,EAAE,IAAI;MACjBC,MAAM,EAAE,EAAE;MACVC,SAAS,EAAE,EAAE;MACbC,SAAS,EAAE,IAAI;MACfC,IAAI,EAAE;IACR,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPP,YAAYA,CAAA,EAAG;MACb,MAAMQ,KAAI,GAAI,IAAIC,IAAI,CAAC,CAAC;MACxB,MAAMC,CAAA,GAAIF,KAAK,CAACG,WAAW,CAAC,CAAC;MAC7B,MAAMC,CAAA,GAAIC,MAAM,CAACL,KAAK,CAACM,QAAQ,CAAC,IAAI,CAAC,CAAC,CAACC,QAAQ,CAAC,CAAC,EAAE,GAAG,CAAC;MACvD,MAAMC,CAAA,GAAIH,MAAM,CAACL,KAAK,CAACS,OAAO,CAAC,CAAC,CAAC,CAACF,QAAQ,CAAC,CAAC,EAAE,GAAG,CAAC;MAClD,OAAO,GAAGL,CAAC,IAAIE,CAAC,IAAII,CAAC,EAAE;IACzB,CAAC;IACDE,MAAMA,CAAA,EAAG;MACP;MACA,IAAI,CAAC,IAAI,CAACjB,SAAQ,IAAK,IAAI,CAACA,SAAQ,KAAM,CAAC,EAAE;QAC3CkB,KAAK,CAAC,WAAW,CAAC;QAClB;MACF;MACA,IAAI,CAAC,IAAI,CAAChB,MAAM,EAAE;QAChBgB,KAAK,CAAC