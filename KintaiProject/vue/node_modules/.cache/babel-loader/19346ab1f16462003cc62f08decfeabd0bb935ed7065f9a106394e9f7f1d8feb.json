;\n}\n\n.form-row {\n  display: flex;\n  flex-direction: column;\n  margin-bottom: 15px;\n}\n\nlabel {\n  font-size: 14px;\n  margin-bottom: 5px;\n}\n\ninput,\ntextarea {\n  padding: 5px;\n  font-size: 14px;\n  border: 1px solid #000;\n  background-color: #fff;\n}\n\ntextarea {\n  resize: vertical;\n}\n\n.button-area {\n  display: flex;\n  justify-content: center;\n  padding: 20px;\n}\n\nbutton {\n  padding: 8px 20px;\n  background-color: #d9d9d9;\n  border: 1px solid #000;\n  cursor: pointer;\n}\n\nbutton:hover {\n  background-color: #c0c0c0;\n}\n\ninput[readonly],\ntextarea[readonly] {\n\tbackground-color: #f0f0f0; /* 閲覧専用だと分かる色 */\n}\n</style>"],"mappings":";AA8CA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAI;AACnC,SAASC,SAAS,QAAQ,YAAW;AACrC,OAAOC,YAAY,MAAM,sCAAsC,EAAE;;;;;;;;IAEjE,MAAMC,MAAM,GAAGF,SAAS,CAAC;IACzB,MAAMG,IAAI,GAAGL,GAAG,CAAC,IAAI;;IAErB;IACAC,SAAS,CAAC,MAAM;MACf,MAAMK,UAAU,GAAGC,cAAc,CAACC,OAAO,CAAC,MAAM;MAChD,IAAIF,UAAU,EAAE;QACfD,IAAI,CAACI,KAAK,GAAGC,IAAI,CAACC,KAAK,CAACL,UAAU;MACnC;IACD,CAAC;IAED,MAAMM,IAAI,GAAGZ,GAAG,CAAC,YAAY;IAC7B,MAAMa,SAAS,GAAGb,GAAG,CAAC,OAAO;IAC7B,MAAMc,MAAM,GAAGd,GAAG,CAAC,MAAM;IACzB,MAAMe,SAAS,GAAGf,GAAG,CAAC,KAAK;IAC3B,MAAMgB,SAAS,GAAGhB,GAAG,CAAC,KAAK;IAC3B,MAAMiB,WAAW,GAAGjB,GAAG,CAAC;AACxB;AACA,0BAA0B;IAG1B,MAAMkB,UAAU,GAAGA,CAAA,KAAM;MACvBd,MAAM,CAACe,IAAI,CAAC,OAAO,CAAC,EAAC;IACvB","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}