: String, required: true },\n    showUser: { type: Boolean, default: false }\n  },\n\n  data() {\n    return {\n      user: {\n        userName: \"\",\n        userId: \"\",\n        role: \"\",\n        name: \"\",\n        team: \"\"\n      }\n    }\n  },\n\n  mounted() {\n    // sessionStorage から user を取得して設定\n    const storedUser = sessionStorage.getItem('user')\n    if (storedUser) {\n      try {\n        const parsed = JSON.parse(storedUser)\n        this.user.userName = parsed.userName || \"\"\n        this.user.userId = parsed.userId || \"\"\n        this.user.role = parsed.role || \"\"\n        this.user.name = parsed.name || \"\"\n        this.user.team = parsed.team || \"\"\n      } catch (e) {\n        console.error('sessionStorageのuserが不正です', e)\n      }\n    }\n  }\n}\n</script>\n\n<style scoped>\n.common-header {\n  width: 100%;\n  height: 60px;\n  background-color: #8ebc75; /* 背景色 */\n  color: white;\n  display: flex;\n  justify-content: space-between; /* 左右に配置 */\n  align-items: center;\n  padding: 0 20px;\n  box-sizing: border-box;\n  border: 1px solid #000;\n}\n.header-left {\n  font-size: 18px;\n  font-weight: bold;\n}\n.header-right span {\n  margin-left: 15px;\n  font-size: 14px;\n}\n</style>"],"mappings":";;EACUA,KAAK,EAAC;AAAe;;EAEtBA,KAAK,EAAC;AAAa;;;EAKnBA,KAAK,EAAC;;;uBAPbC,mBAAA,CAYS,UAZTC,UAYS,GAXPC,mBAAA,YAAe,EACfC,mBAAA,CAEM,OAFNC,UAEM,EAAAC,gBAAA,CADDC,MAAA,CAAAC,KAAK,kBAGVL,mBAAA,yBAA4B,EACII,MAAA,CAAAE,QAAQ,I,cAAxCR,mBAAA,CAIM,OAJNS,UAIM,GAHJN,mBAAA,CAA+B,cAAzB,KAAG,GAAAE,gBAAA,CAAGK,KAAA,CAAAC,IAAI,CAACC,IAAI,kBACrBT,mBAAA,CAA+B,cAAzB,KAAG,GAAAE,gBAAA,CAAGK,KAAA,CAAAC,IAAI,CAACE,IAAI,kBACrBV,mBAAA,CAAkC,cAA5B,QAAM,GAAAE,gBAAA,CAAGK,KAAA,CAAAC,IAAI,CAACG,IAAI,iB","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}