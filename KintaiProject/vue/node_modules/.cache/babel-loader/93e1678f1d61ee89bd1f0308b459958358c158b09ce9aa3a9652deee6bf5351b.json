る props（必要であれば残す）\nconst props = defineProps({\n  showUser: { type: Boolean, default: false }\n})\n\n// ヘッダーに表示する user 情報を保持\nconst user = reactive({\n  userName: \"\",\n  userId: \"\",\n  role: \"\",\n  name: \"\",\n  team: \"\"\n})\n\n// 画面表示のたびに sessionStorage から user を読み込む\nonMounted(() => {\n  const storedUser = sessionStorage.getItem('user')\n  if (storedUser) {\n    try {\n      const parsed = JSON.parse(storedUser)\n      user.userName = parsed.userName || \"\"\n      user.userId = parsed.userId || \"\"\n      user.role = parsed.role || \"\"\n      user.name = parsed.name || \"\"\n      user.team = parsed.team || \"\"\n    } catch (e) {\n      console.error('sessionStorageのuserが不正です', e)\n    }\n  }\n})\n</script>\n\n<style scoped>\n.common-header {\n  width: 100%;\n  height: 60px;\n  background-color: #8ebc75; /* 背景色 */\n  color: white;\n  display: flex;\n  justify-content: space-between; /* 左右に配置 */\n  align-items: center;\n  padding: 0 20px;\n  box-sizing: border-box;\n  border: 1px solid #000;\n}\n.header-left {\n  font-size: 18px;\n  font-weight: bold;\n}\n.header-right span {\n  margin-left: 15px;\n  font-size: 14px;\n}\n</style>"],"mappings":";;EACUA,KAAK,EAAC;AAAe;;EAEtBA,KAAK,EAAC;AAAa;;;EAKnBA,KAAK,EAAC;;;uBAPbC,mBAAA,CAYS,UAZTC,UAYS,GAXPC,mBAAA,YAAe,EACfC,mBAAA,CAEM,OAFNC,UAEM,EAAAC,gBAAA,CADDC,IAAA,CAAAC,KAAK,kBAGVL,mBAAA,yBAA4B,EACIM,MAAA,CAAAC,QAAQ,I,cAAxCT,mBAAA,CAIM,OAJNU,UAIM,GAHJP,mBAAA,CAA+B,cAAzB,KAAG,GAAAE,gBAAA,CAAGM,MAAA,CAAAC,IAAI,CAACC,IAAI,kBACrBV,mBAAA,CAA+B,cAAzB,KAAG,GAAAE,gBAAA,CAAGM,MAAA,CAAAC,IAAI,CAACE,IAAI,kBACrBX,mBAAA,CAAkC,cAA5B,QAAM,GAAAE,gBAAA,CAAGM,MAAA,CAAAC,IAAI,CAACG,IAAI,iB","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}