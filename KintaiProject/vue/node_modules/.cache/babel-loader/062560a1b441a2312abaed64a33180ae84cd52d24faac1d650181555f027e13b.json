ar\">クリア</button>\n      <button @click=\"handleTest\">バックエンド検証</button>\n      <p v-if=\"department\">{{ department.departmentName }}</p>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref } from 'vue'\nimport { useRouter } from 'vue-router'\nimport CommonHeader from '@/components/common/CommonHeader.vue'  // 共通ヘッダー\nimport { mockLogin } from '@/mocks/mockApi.js' //モック\nimport axios from 'axios';\n\n\n\nconst userId = ref('')\nconst password = ref('')\nconst message = ref('ユーザIDとパスワードを入力してください')\n\nconst router = useRouter()\n\n/** \nconst handleLogin = async () => {\n  if (!userId.value || !password.value) {\n    message.value = 'ユーザIDとパスワードを入力してください'\n    return\n  }\n\n  try {\n    // DB検索を想定したAPI呼び出し（モック用）\n    const response = await fetch('/api/login', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({\n        userId: userId.value,\n        password: password.value\n      })\n    })\n\n    if (!response.ok) {\n      throw new Error('サーバエラー')\n    }\n\n    const result = await response.json()\n\n    if (result.success) {\n      // ログイン成功時\n      sessionStorage.setItem('user', JSON.stringify(result.user))\n      router.push('/menu')\n    } else {\n      message.value = 'ユーザIDまたはパスワードが正しくありません'\n    }\n  } catch (err) {\n    console.error(err)\n    message.value = '通信エラーが発生しました'\n  }\n}\n\nconst handleClear = () => {\n  userId.value = ''\n  password.value = ''\n  message.value = '画面上部メッセージ'\n}\n */\n\n// ここから \n const handleLogin = async () => {\n   if (!userId.value || !password.value) {\n     message.value = 'ユーザIDとパスワードは必須項目です'\n     return\n   }\n\n   try {\n     // fetch の代わりにモック関数を呼ぶ\n     // mockApi.jsに記載したユーザIDとパスワードでログインできる\n     const result = await mockLogin({\n       userId: userId.value,\n       password: password.value\n     })\n\n     if (result.success) {\n        // ログイン成功時\n        sessionStorage.setItem('user', JSON.stringify(result.user))\n        router.push('/menu')\n     } else {\n       message.value = 'ユーザIDまたはパスワードが間違っています'\n     }\n   } catch (err) {\n     console.error(err)\n     message.value = '通信エラーが発生しました'\n   }\n }\n\nconst handleClear = () => {\n  userId.value = ''\n  password.value = ''\n  message.value = 'ユーザIDとパスワードを入力してください'\n}\n\nconst handleTest = () => {\n    methods: {\n      async fetchDepartment() {\n        try {\n          const response = await axios.get(\"http://localhost:8080/api/departmentMsts/D001\");\n          console.log(response.data);\n        } catch (error) {\n          console.error(error);\n        }\n      }\n    }\n\n}\n// ここまで、モック用 */\n</script>\n\n<style scoped>\n\n/* メッセージエリア */\n.message-area {\n  padding: 10px;\n  border-bottom: 1px solid #000;\n  font-size: 14px;\n}\n\n/* 入力フォームエリア */\n.form-area {\n  padding: 20px 30px 10px;\n}\n\n.form-row {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  margin-bottom: 15px;\n}\n\n/* 入力欄名(ユーザIDとか) */\nlabel {\n  width: 100px;\n  font-size: 14px;\n  text-align: right;\n  margin-right: 8px;\n}\n\n/* 入力欄 */\ninput {\n  flex: none;\n  width: 50%;\n  padding: 5px;\n  font-size: 14px;\n  border: 1px solid #000;\n}\n\n/* ボタンエリア */\n.button-area {\n  display: flex;\n  justify-content: center;\n  gap: 20px;\n  padding: 20px;\n}\n\nbutton {\n  padding: 8px 20px;\n  background-color: #d9d9d9;\n  border: 1px solid #000;\n  cursor: pointer;\n}\n\nbutton:hover {\n  background-color: #c0c0c0;\n}\n</style>\n"],"mappings":";;EACOA,KAAK,EAAC;AAAiB;;EAKrBA,KAAK,EAAC;AAAc;;EAGpBA,KAAK,EAAC;AAAW;;EACfA,KAAK,EAAC;AAAU;;EAIhBA,KAAK,EAAC;AAAU;;EAOlBA,KAAK,EAAC;AAAa;;;;;;uBApB1BC,mBAAA,CA0BM,OA1BNC,UA0BM,GAzBJC,mBAAA,UAAa,EACbC,YAAA,CAA6BC,uBAAA;IAAfC,KAAK,EAAC;EAAM,IAE1BH,mBAAA,cAAiB,EACjBI,mBAAA,CAA6C,OAA7CC,UAA6C,EAAAC,gBAAA,CAAhBC,IAAA,CAAAC,OAAO,kBAEpCR,mBAAA,WAAc,EACdI,mBAAA,CASM,OATNK,UASM,GARJL,mBAAA,CAGM,OAHNM,UAGM,G,0BAFJN,mBAAA,CAAiC;IAA1BO,GAAG,EAAC;EAAQ,GAAC,OAAK,qB,gBACzBP,mBAAA,CAAkD;IAA3CQ,IAAI,EAAC,MAAM;IAACC,EAAE,EAAC,QAAQ;+DAA