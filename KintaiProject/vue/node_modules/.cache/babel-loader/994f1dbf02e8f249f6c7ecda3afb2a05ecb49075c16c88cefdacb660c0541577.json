{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref } from 'vue';\nimport { useRouter } from 'vue-router';\nexport default {\n  __name: 'LoginForm',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const userId = ref('');\n    const password = ref('');\n    const router = useRouter();\n    const handleLogin = () => {\n      // ここでログイン認証処理をする場合は追加\n      // 今はモックで必ず遷移させる\n\n      router.push('/menu'); // '/menu' に遷移\n    };\n    const handleClear = () => {\n      userId.value = '';\n      password.value = '';\n    };\n    const __returned__ = {\n      userId,\n      password,\n      router,\n      handleLogin,\n      handleClear,\n      ref,\n      get useRouter() {\n        return useRouter;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","useRouter","userId","password","router","handleLogin","push","handleClear","value"],"sources":["C:/Users/yu-yoshida/Desktop/pleiades-2025-06-java-win-64bit-jre_20250615/workspace/kintai/vue/src/components/LoginForm.vue"],"sourcesContent":["<template>\n  <div class=\"login-container\">\n    <!-- ヘッダー -->\n    <div class=\"header\">ログイン</div>\n\n    <!-- メッセージエリア -->\n    <div class=\"message-area\">画面上部メッセージ</div>\n\n    <!-- 入力エリア -->\n    <div class=\"form-area\">\n      <div class=\"form-row\">\n        <label for=\"userId\">ユーザID</label>\n        <input type=\"text\" id=\"userId\" v-model=\"userId\" />\n      </div>\n      <div class=\"form-row\">\n        <label for=\"password\">パスワード</label>\n        <input type=\"password\" id=\"password\" v-model=\"password\" />\n      </div>\n    </div>\n\n    <!-- ボタンエリア -->\n    <div class=\"button-area\">\n      <button @click=\"handleLogin\">ログイン</button>\n      <button @click=\"handleClear\">クリア</button>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref } from 'vue'\