ick=\"goDetail(item.id)\">詳細</button></td>\n        </tr>\n      </tbody>\n    </table>\n\n    <button @click=\"exportFile\">ファイル出力</button>\n  </div>\n</template>\n\n<script setup>\nimport { ref } from 'vue'\nimport { useRouter } from 'vue-router'\nimport CommonHeader from '@/components/common/CommonHeader.vue'  // 共通ヘッダー\n\nconst router = useRouter()\n\nconst filters = ref({\n  selfOnly: false,\n  startDate: '',\n  endDate: '',\n  team: '',\n  name: ''\n})\n\nconst results = ref([])\n\nconst search = () => {\n  // TODO: ここにDB検索やAPI呼び出しのコードを追加してください\n  console.log('検索条件:', filters.value)\n  \n  // モックデータを返す例\n  results.value = [\n    { id: 1, name: '山田太郎', team: '営業', date: '2025/08/20', reason: '遅刻', train: '〇〇線', delayTime: '10分' },\n    { id: 2, name: '佐藤花子', team: '開発', date: '2025/08/19', reason: '早退', train: '-', delayTime: '-' }\n    // 他のモックデータも追加可能\n  ]\n}\n\nconst clearFilters = () => {\n  filters.value = { selfOnly: false, startDate: '', endDate: '', team: '', name: '' }\n  results.value = []\n}\n\nconst goBack = () => {\n  router.push('/menu')\n}\n\nconst goDetail =() => {\n\trouter.push('/kintai-detail')\n}\n//const goDetail = (id) => {\n//  router.push(`/kintai-detail/${id}`) 一旦コメントアウト\n//}\n\nconst exportFile = () => {\n  // TODO: ファイル出力のロジックを実装してください\n  alert('ファイル出力機能は未実装です')\n}\n</script>\n\n<style scoped>\n/* 必要に応じてスタイル追加してください */\n</style>\n"],"mappings":";AA0DA,SAASA,GAAG,QAAQ,KAAI;AACxB,SAASC,SAAS,QAAQ,YAAW;AACrC,OAAOC,YAAY,MAAM,sCAAsC,EAAE;;;;;;;;IAEjE,MAAMC,MAAM,GAAGF,SAAS,CAAC;IAEzB,MAAMG,OAAO,GAAGJ,GAAG,CAAC;MAClBK,QAAQ,EAAE,KAAK;MACfC,SAAS,EAAE,EAAE;MACbC,OAAO,EAAE,EAAE;MACXC,IAAI,EAAE,EAAE;MACRC,IAAI,EAAE;IACR,CAAC;IAED,MAAMC,OAAO,GAAGV,GAAG,CAAC,EAAE;IAEtB,MAAMW,MAAM,GAAGA,CAAA,KAAM;MACnB;MACAC,OAAO,CAACC,GAAG,CAAC,OAAO,EAAET,OAAO,CAACU,KAAK;;MAElC;MACAJ,OAAO,CAACI,KAAK,GAAG,CACd;QAAEC,EAAE,EAAE,CAAC;QAAEN,IAAI,EAAE,MAAM;QAAED,IAAI,EAAE,IAAI;QAAEQ,IAAI,EAAE,YAAY;QAAEC,MAAM,EAAE,IAAI;QAAEC,KAAK,EAAE,KAAK;QAAEC,SAAS,EAAE;MAAM,CAAC,EACrG;Q